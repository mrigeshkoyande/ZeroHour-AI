# ─────────────────────────────────────────────────────────────────────────────
# ZeroHour AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
VITE_APP_NAME=ZeroHour AI
VITE_APP_VERSION=3.0.0

# Google Gemini API (for future live AI integration)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-pro

# Google Calendar OAuth (for future live calendar sync)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Feature Flags
VITE_ENABLE_LIVE_AI=false
VITE_ENABLE_GOOGLE_SYNC=false
